# =========================================================================
# Template Environment Variables for Production
# คัดลอกไฟล์นี้ไปสร้างเป็นไฟล์ชื่อ `.env` บนเซิร์ฟเวอร์ และเปลี่ยนค่าตัวแปรด้านล่าง
# =========================================================================

# Binds to Hono Production Server Environment
NODE_ENV="production"
PORT=3000

# -------------------------------------------------------------------------
# 1. Database Configuration (PostgreSQL)
# -------------------------------------------------------------------------
# กำหนด Username, Database Name และรหัสผ่านสุ่มที่มีความปลอดภัยสูงสำหรับระบบโปรดักชัน
DB_USER="currency_user"
DB_NAME="currency_db"
DB_PASSWORD="SECURE_RANDOM_PASSWORD_HERE" # <<< ใส่รหัสผ่านสุ่มที่มีความยาวและความปลอดภัยสูงที่นี่

# -------------------------------------------------------------------------
# 2. Authentication Configuration (Better Auth)
# -------------------------------------------------------------------------
# คีย์ลับสำหรับระบบยืนยันตัวตน (สุ่มคีย์ยาวๆ หรือใช้คำสั่ง: openssl rand -hex 32 ใน Linux)
BETTER_AUTH_SECRET="SECURE_GENERATED_HEX_SECRET_HERE" # <<< ใส่คีย์สุ่มที่นี่

# URL สาธารณะของโดเมนการใช้งานจริงผ่าน HTTPS (ห้ามใส่ localhost เด็ดขาด)
BETTER_AUTH_URL="https://currency.tummy.cc"

# -------------------------------------------------------------------------
# 3. Security (CORS) & Bank API
# -------------------------------------------------------------------------
# ระบุ Origin ที่ยอมรับสำหรับการทำงาน (คั่นด้วยเครื่องหมายจุลภาคหากมีหลายโดเมน)
ALLOWED_ORIGINS="https://currency.tummy.cc"

# API Key สำหรับดึงอัตราแลกเปลี่ยนจริงจากธนาคารแห่งประเทศไทย (BOT)
BOT_API_KEY="your-production-bot-api-key-here"
